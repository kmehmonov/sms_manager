<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════════
         YUQORI PANEL
         ══════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/app_subtitle"
                android:textColor="#B3DAFE"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Yangilanish banneri — yangi versiya topilganda ko'rinadi -->
        <LinearLayout
            android:id="@+id/layoutUpdateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A3A6E"
            android:paddingStart="20dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvUpdateTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🆕 Yangi versiya mavjud!"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Yuklab olish"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                style="@style/Widget.Material3.Button.TonalButton"
                android:backgroundTint="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════
         ASOSIY KONTENT
         ══════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── 1. CSV FAYL KARTASI ─────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/CardStyle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Bo'lim sarlavhasi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_file"
                            style="@style/SectionTitle" />

                    </LinearLayout>

                    <!-- Fayl tanlash tugmasi -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_select_file"
                        style="@style/OutlinedButton"
                        app:icon="@android:drawable/ic_menu_agenda"
                        app:iconGravity="textStart"
                        app:iconSize="18dp" />

                    <!-- Tanlangan fayl ma'lumoti (bosiladigan) -->
                    <LinearLayout
                        android:id="@+id/layoutFileInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_file_info"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFileName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                tools:text="contacts.csv" />

                            <TextView
                                android:id="@+id/tvContactCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/success"
                                android:textSize="12sp"
                                tools:text="120 ta raqam" />

                        </LinearLayout>

                        <!-- Ko'rish tugmasi -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPreviewCsv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_preview"
                            android:textSize="12sp"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:textColor="@color/primary" />

                    </LinearLayout>

                    <!-- Fayl tanlanmagan holat -->
                    <LinearLayout
                        android:id="@+id/layoutNoFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no_file_selected"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── 2. SOZLAMALAR KARTASI ───────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/CardStyle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Bo'lim sarlavhasi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_settings"
                            style="@style/SectionTitle" />

                    </LinearLayout>

                    <!-- Sarlavha checkbox -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkSkipHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/skip_header"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp" />

                    <!-- Kutish vaqti sarlavhasi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_delay"
                        style="@style/SectionTitle"
                        android:layout_marginBottom="12dp" />

                    <!-- Min / Max delay inputlar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Min delay -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMinDelay"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:hint="@string/delay_min_label"
                            app:suffixText="@string/delay_suffix"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMinDelay"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:text="4"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Max delay -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMaxDelay"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/delay_max_label"
                            app:suffixText="@string/delay_suffix"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMaxDelay"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:text="6"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- SIM karta tanlash (ko'p SIM li qurilmalarda ko'rinadi) -->
                    <LinearLayout
                        android:id="@+id/layoutSimSelector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SIM karta:"
                            style="@style/SectionTitle"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilSimSelector"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="SIM karta tanlash"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <AutoCompleteTextView
                                android:id="@+id/spinnerSim"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Batch tanaffus haqida ma'lumot -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/batch_pause_info"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:drawablePadding="6dp"
                        app:drawableStartCompat="@android:drawable/ic_dialog_info" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── 3. BOSHQARUV TUGMALARI ─────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:enabled="false"
                    android:text="@string/btn_start"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    style="@style/PrimaryButton"
                    android:backgroundTint="@color/success"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconSize="18dp"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="@string/btn_stop"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    style="@style/PrimaryButton"
                    android:backgroundTint="@color/error"
                    app:icon="@android:drawable/ic_media_pause"
                    app:iconSize="18dp"
                    app:iconGravity="textStart" />

            </LinearLayout>

            <!-- ── 4. STATISTIKA QATORI ───────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Yuborildi -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/CardStyle"
                    app:cardBackgroundColor="@color/success_light">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatSent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/success"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yuborildi"
                            android:textColor="@color/success"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Xato -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/CardStyle"
                    app:cardBackgroundColor="@color/error_light">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatFailed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/error"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xato"
                            android:textColor="@color/error"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Jami -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/CardStyle"
                    app:cardBackgroundColor="@color/primary_light">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jami"
                            android:textColor="@color/primary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── 5. PROGRESS KARTASI ────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/CardStyle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Progress foizi va raqami -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/tvProgress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/progress_idle"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProgressPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Progress bar -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:trackCornerRadius="6dp"
                        app:trackThickness="8dp"
                        app:indicatorColor="@color/primary"
                        app:trackColor="@color/primary_light" />

                    <!-- Joriy holat xabari -->
                    <TextView
                        android:id="@+id/tvCurrentStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── 6. LOG KARTASI ─────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Log sarlavhasi + tozalash tugmasi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="8dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_log"
                            style="@style/SectionTitle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearLog"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_clear"
                            android:textSize="12sp"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <!-- Log RV — o'zida scroll bor -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerLog"
                        android:layout_width="match_parent"
                        android:layout_height="420dp"
                        android:nestedScrollingEnabled="true"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp"
                        tools:itemCount="5"
                        tools:listitem="@layout/item_log" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pastki bo'sh joy -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
