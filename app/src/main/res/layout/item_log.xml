<?xml version="1.0" encoding="utf-8"?>
<!--
    Log ro'yxatidagi har bir element ko'rinishi.
    Har bir SMS uchun: raqam, xabar, holat belgisi ko'rsatiladi.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <!-- Holat belgisi: ✓ (yashil), ✗ (qizil), ⏳ (kulrang) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="⏳" />

    <!-- Raqam va xabar ma'lumotlari -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <!-- Telefon raqami -->
        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="+998901234567" />

        <!-- Xabarning qisqartirilgan ko'rinishi -->
        <TextView
            android:id="@+id/tvMessagePreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Salom, bu test xabari..." />

        <!-- Xato yuz berganda xato xabari ko'rinadi -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/error"
            android:visibility="gone"
            tools:text="Xato: Noto'g'ri raqam formati"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- Tartib raqami -->
    <TextView
        android:id="@+id/tvIndex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        tools:text="#1" />

</LinearLayout>
